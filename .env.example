# MergeGuard AI — P3 Analysis Service
# Copy to .env and fill in values: cp .env.example .env

# --- MergeGuard pipeline ---
MERGEGUARD_BASE_URL=http://127.0.0.1:8000

# --- P1/P2 v2 sandbox (Agenthacks) ---
GITHUB_TOKEN=
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us
# Set true to return mock Daytona sandbox responses without calling the API
DAYTONA_MOCK_MODE=false

# --- Groq agent (Tier 1: LLM-driven Opsera MCP workflow) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Opsera MCP / OAuth ---
OPSERA_MCP_URL=https://agent.opsera.ai/mcp
OPSERA_OAUTH_ISSUER=https://agent.opsera.ai
OPSERA_REDIRECT_URI=http://127.0.0.1:8000/auth/opsera/callback
OPSERA_DATA_DIR=.opsera

# --- Scan behavior ---
# Set true to skip OAuth + live scans and return mock findings only
OPSERA_MOCK_MODE=false
